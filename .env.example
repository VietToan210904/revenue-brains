# Runtime
APP_ENV=development
PYTHON_AGENT_URL=http://localhost:8000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Postgres local infrastructure
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=revenue_brains
POSTGRES_USER=revenue_brains
POSTGRES_PASSWORD=change-me-local-only
DATABASE_URL=postgresql://revenue_brains:change-me-local-only@localhost:5432/revenue_brains

# Qdrant local infrastructure
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=revenue_brains_documents
QDRANT_VECTOR_SIZE=1536
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# Private local attachment storage, ignored by Git
UPLOAD_STORAGE_PATH=./uploads

# Future webhook sync placeholders
WEBHOOK_URL=
WEBHOOK_SECRET=
